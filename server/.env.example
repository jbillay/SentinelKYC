# Server configuration — copy to server/.env and fill in.
# server/.env is git-ignored. NEVER commit real keys.

# ---------------------------------------------------------------------------
# Companies House — required
# Sign up: https://developer.company-information.service.gov.uk/
# ---------------------------------------------------------------------------
CH_API_KEY=

# ---------------------------------------------------------------------------
# Postgres — required (see server/db/SETUP.md)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://kyc_poc:CHANGE_ME@localhost:5432/kyc_poc

# ---------------------------------------------------------------------------
# Express
# ---------------------------------------------------------------------------
PORT=3000

# ---------------------------------------------------------------------------
# LLM provider selection — pick one per task.
#   ollama: local glm-ocr / llama3.1:8b
#   nvidia: hosted NIMs (requires NVIDIA_API_KEY below)
# ---------------------------------------------------------------------------
LLM_OCR_PROVIDER=ollama
LLM_REASON_PROVIDER=ollama

# Ollama (default — only needed if any LLM_*_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_OCR_MODEL=glm-ocr
OLLAMA_REASON_MODEL=llama3.1:8b

# NVIDIA NIM (only needed if any LLM_*_PROVIDER=nvidia)
# Token: https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_OCR_MODEL=
NVIDIA_REASON_MODEL=

# ---------------------------------------------------------------------------
# Adverse media (GDELT 2.0 DOC API) — optional overrides.
# Defaults are baked in; no API key required.
# ---------------------------------------------------------------------------
# GDELT_DOC_ENDPOINT=https://api.gdeltproject.org/api/v2/doc/doc
# GDELT_TIMESPAN=12m

# --- Auth / sessions (R1) ---
# Long random string (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`).
SESSION_SECRET=
# COOKIE_SECURE=true        # set true behind HTTPS in production
# SESSION_TTL_MS=86400000   # session lifetime in ms (default 1 day)
# BCRYPT_COST=12
# AUTH_DEV_BYPASS=false     # local-only: trust x-user-id when set; keep OFF
# Initial passwords for `npm run users:seed` (set, then run the seed once).
SEED_ANALYST_PASSWORD=
SEED_REVIEWER_PASSWORD=
SEED_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Durable run execution (R2)
#   inline (default): runs execute in the web process, SSE from memory — no
#           worker needed, behaves exactly as before.
#   queue:  runs execute in a separate worker (`npm run worker`) via pg-boss;
#           SSE crosses the process boundary through the run_events table +
#           LISTEN/NOTIFY. Durable: a web restart no longer loses an in-flight
#           run. No speedup — Ollama stays serial.
# ---------------------------------------------------------------------------
RUN_EXECUTION=inline
# PGBOSS_SCHEMA=pgboss        # Postgres schema pg-boss manages (auto-created)
# WORKER_CONCURRENCY=1        # parallel jobs per worker (keep 1 for Ollama)
# WORKER_RECONCILE=on         # re-drive crashed in-flight runs on worker boot
